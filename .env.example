# ── NVIDIA NIM (AI explanations) ──
# Optional. ReadAura now takes the NVIDIA API key from the in-app
# Settings dialog (stored in your browser's localStorage). This env var
# is a server-side fallback for headless or shared self-hosted setups —
# leave it blank for the default per-browser flow.
# Get a free key at https://build.nvidia.com/
NVIDIA_API_KEY=

# Optional: override default DB path (defaults to ./readaura.db in project root)
# READAURA_DB_PATH=/absolute/path/to/readaura.db
